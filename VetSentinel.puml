@startuml VetSentinel

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam class {
    BackgroundColor #FFFEF0
    BorderColor #8B6914
    ArrowColor #555555
}

class Main {
    + {static} main(args: String[]) : void
}

class ConexionDB {
    - {static} URL : String
    --
    + {static} getConexion() : Connection
    + {static} inicializarBD() : void
    + {static} obtenerTodosLosParasitos() : List<Parasito>
    + {static} obtenerEstadisticasEpidemiologicas() : String
    + {static} upsertPropietario(p: Propietario) : int
    + {static} buscarPropietarioPorCedula(cedula: String) : Propietario
    + {static} upsertMascota(m: Mascota) : int
    + {static} insertarDiagnostico(idMasc: int, idPar: int, nivelRiesgo: String) : void
}

class Propietario {
    - id : int
    - cedula : String
    - nombre : String
    - direccion : String
    - tieneNinos : boolean
    - hayEmbarazadas : boolean
    --
    + Propietario(id, cedula, nombre, direccion, tieneNinos, hayEmbarazadas)
    + getId() : int
    + setId(id: int) : void
    + getCedula() : String
    + getNombre() : String
    + getDireccion() : String
    + isTieneNinos() : boolean
    + isHayEmbarazadas() : boolean
}

class Mascota {
    - id : int
    - nombre : String
    - especie : String
    - edad : int
    - propietario : Propietario
    --
    + Mascota(id, nombre, especie, edad, propietario)
    + getId() : int
    + setId(id: int) : void
    + getNombre() : String
    + getEspecie() : String
    + getEdad() : int
    + getPropietario() : Propietario
}

class Parasito {
    - id : int
    - nombre : String
    - riesgoPrincipal : String
    - medidasPreventivas : String
    - alertaEmbarazo : boolean
    - alertaNinos : boolean
    --
    + Parasito(id, nombre, riesgoPrincipal, medidasPreventivas, alertaEmbarazo, alertaNinos)
    + getId() : int
    + getNombre() : String
    + getRiesgoPrincipal() : String
    + getMedidasPreventivas() : String
    + isAlertaEmbarazo() : boolean
    + isAlertaNinos() : boolean
    + toString() : String
}

class Diagnostico {
    - id : int
    - mascota : Mascota
    - parasito : Parasito
    - fecha : String
    - estadoContagio : String
    --
    + Diagnostico(id, mascota, parasito, fecha, estadoContagio)
    + evaluarRiesgoHumano() : String
    + getId() : int
    + getMascota() : Mascota
    + getParasito() : Parasito
    + getFecha() : String
    + getEstadoContagio() : String
}

class VentanaVeterinaria {
    - isDarkMode : boolean
    - updaters : List<Runnable>
    - txtNombreMascota : JTextField
    - txtEdadMascota : JTextField
    - cbEspecie : JComboBox<String>
    - cbParasito : JComboBox<Parasito>
    - txtCedula : JTextField
    - txtNombrePropietario : JTextField
    - txtDireccion : JTextField
    - chkEmbarazadas : JCheckBox
    - chkNinos : JCheckBox
    - btnGuardar : JButton
    - btnVerHistorial : JButton
    - btnEstadisticas : JButton
    - alertPanel : JPanel
    - alertIconLabel : JLabel
    - alertNivelLabel : JLabel
    - alertTextArea : JTextArea
    - alertMascotaLabel : JLabel
    --
    + VentanaVeterinaria()
    - aplicarColores(oscuro: boolean) : void
    - alternarTema() : void
    - actualizarUI() : void
    - buildHeader() : JPanel
    - buildCenter() : JPanel
    - buildFormPanel() : JPanel
    - buildAlertPanel() : JPanel
    - wireListeners() : void
    - buscarClienteAutocompletar() : void
    - guardarYMostrarAlerta() : void
    - mostrarAlertaEnPanel(alerta: String, mascota: String, especie: String, parasito: String) : void
    - verHistorial() : void
    - verEstadisticas() : void
    - resetAlertPanel() : void
}

' Relaciones
Main ..> ConexionDB : <<usa>>
Main ..> VentanaVeterinaria : <<crea>>

VentanaVeterinaria ..> ConexionDB : <<usa>>
VentanaVeterinaria ..> Diagnostico : <<crea>>
VentanaVeterinaria ..> Mascota : <<crea>>
VentanaVeterinaria ..> Parasito : <<crea>>
VentanaVeterinaria ..> Propietario : <<crea>>

Diagnostico "1" --> "1" Mascota : mascota
Diagnostico "1" --> "1" Parasito : parasito
Mascota "1" --> "1" Propietario : propietario

@enduml